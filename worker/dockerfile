# Stage 1: Build stage (The Kitchen)
FROM python:3.12-slim AS builder

WORKDIR /app
COPY requirements.txt .
RUN pip install --user --no-cache-dir -r requirements.txt

# Stage 2: Final stage (The Dining Room)
FROM FROM python:3.12-slim

# Create the non-root user
RUN useradd -m blessing_benedicta_bill
WORKDIR /home/blessing_benedicta_bill/app

# Copy the "cooked" packages and code
COPY --from=builder /root/.local /home/blessing_benedicta_bill/.local
COPY --chown=blessing_benedicta_bill:blessing_benedicta_bill . .

# Set the environment paths
ENV PATH=/home/blessing_benedicta_bill/.local/bin:$PATH
ENV PYTHONUNBUFFERED=1

USER blessing_benedicta_bill

# The Heartbeat: Checking if 'worker.py' is still running
HEALTHCHECK --interval=30s --timeout=10s --start-period=5s --retries=3 \
  CMD pgrep -f "python worker.py" || exit 1

# Start the worker
CMD ["python", "worker.py"]
